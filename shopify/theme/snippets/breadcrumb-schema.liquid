{%- comment -%}
  BreadcrumbList JSON-LD for product / collection / page templates.
{%- endcomment -%}
{%- if request.page_type == 'product' or request.page_type == 'collection' or request.page_type == 'page' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'general.breadcrumbs.home' | t | json }},
      "item": {{ shop.url | append: routes.root_url | json }}
    }
    {%- if request.page_type == 'product' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.title | json }},
      "item": {{ shop.url | append: product.url | json }}
    }
    {%- elsif request.page_type == 'collection' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": {{ shop.url | append: collection.url | json }}
    }
    {%- elsif request.page_type == 'page' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": {{ shop.url | append: page.url | json }}
    }
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
