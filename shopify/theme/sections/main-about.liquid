{%- comment -%}
  Our Story — migrated from the static about.html. Copy ships as schema
  defaults so the page renders faithfully on first deploy; every line is
  editable in the theme editor. If the Shopify page carries its own content,
  it renders after the manifesto (merchant additions never get lost).
{%- endcomment -%}
<section class="page-hero-sub">
  <div class="wrap">
    <nav class="crumb" aria-label="{{ 'general.breadcrumbs.label' | t }}">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a><span class="sep">/</span><span class="here">{{ page.title }}</span>
    </nav>
    <div class="sec-id">{{ section.settings.eyebrow }}</div>
    <h1 class="page-h1">{{ section.settings.headline }}</h1>
  </div>
</section>

<section class="sys">
  <div class="wrap">
    <div class="stat-row about-stats">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="stat" {{ block.shopify_attributes }}>
            <div class="stat-n tabular">{{ block.settings.value }}</div>
            <div class="stat-l">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<section class="sys">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-id">{{ section.settings.manifesto_eyebrow }}</div>
      <div>
        <h2 class="sec-title">{{ section.settings.manifesto_heading }}</h2>
      </div>
    </div>
    <div class="rte about-manifesto">{{ section.settings.manifesto }}</div>
    {%- if section.settings.signoff != blank -%}
      <p class="about-signoff">{{ section.settings.signoff }}</p>
    {%- endif -%}
  </div>
</section>

<section class="sys">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-id">{{ section.settings.mission_eyebrow }}</div>
      <div>
        <h2 class="sec-title">{{ section.settings.mission_heading }}</h2>
        {%- if section.settings.mission_lede != blank -%}<p class="sec-lede">{{ section.settings.mission_lede }}</p>{%- endif -%}
      </div>
    </div>
    <div class="benefit-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'promise' -%}
          <article class="benefit-card" {{ block.shopify_attributes }}>
            <div class="sec-id">{{ block.settings.eyebrow }}</div>
            <h3>{{ block.settings.heading }}</h3>
            <p>{{ block.settings.body }}</p>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if page.content != blank -%}
      <div class="rte">{{ page.content }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No. 04 · Our story · London · MMXXVI" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Built so a pound leaves before the profit does." },
    { "type": "text", "id": "manifesto_eyebrow", "label": "Manifesto eyebrow", "default": "01 · The Manifesto" },
    { "type": "text", "id": "manifesto_heading", "label": "Manifesto heading", "default": "Why HerBody exists" },
    { "type": "richtext", "id": "manifesto", "label": "Manifesto", "default": "<p>HerBody was made because the supplement shelf is full of small lies — marketing doses, made-for-Instagram pastel pouches, charity logos that never lead anywhere honest. And because halal, on that shelf, almost never meant clinical.</p><p>We made one pouch instead of nine. Every nutrient she'd otherwise have to buy from seven brands, at clinical dose, in a flavour she actually likes. Halal by default — not as a feature, as the floor.</p><p>Then we made it so that her care funds another woman's care. A pound and a tenth from every pouch, to one of eight partners she chooses. The pound leaves before the profit is calculated. The four Asian partners are audited annually for zero-tolerance on corruption. The receipts are published quarterly, signed.</p><p>Profit is the fuel. It is never the destination.</p>" },
    { "type": "text", "id": "signoff", "label": "Sign-off", "default": "— The founders · London · January 2026 · Vol. 26 No. 01" },
    { "type": "text", "id": "mission_eyebrow", "label": "Mission eyebrow", "default": "02 · The Mission" },
    { "type": "text", "id": "mission_heading", "label": "Mission heading", "default": "Value, measured in lives. Not in margin." },
    { "type": "text", "id": "mission_lede", "label": "Mission lede", "default": "Every decision inside HerBody is asked the same question first: does this make her life, or a sister's life, materially better? If the honest answer is no, we don't do it — even when the spreadsheet says we should." }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "8" },
        { "type": "text", "id": "label", "label": "Label", "default": "Charity partners" }
      ]
    },
    {
      "type": "promise",
      "name": "Promise",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "i · Promise" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Clinical dose, always." },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Every ingredient at the dose studied in published trials. Not \"active\". Not \"supportive\". The actual dose." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story",
      "blocks": [
        { "type": "stat", "settings": { "value": "2026", "label": "Founded · London" } },
        { "type": "stat", "settings": { "value": "3", "label": "Founders" } },
        { "type": "stat", "settings": { "value": "8", "label": "Charity partners" } },
        { "type": "stat", "settings": { "value": "£10M", "label": "Given by 2030" } },
        { "type": "stat", "settings": { "value": "1M", "label": "Women reached by 2030" } },
        { "type": "promise", "settings": { "eyebrow": "i · Promise", "heading": "Clinical dose, always.", "body": "Every ingredient at the dose studied in published trials. Not \"active\". Not \"supportive\". The actual dose." } },
        { "type": "promise", "settings": { "eyebrow": "ii · Promise", "heading": "Halal by default.", "body": "No gelatin, no alcohol carriers, no haram excipients. Halal Food Authority, GB18 / 2026." } },
        { "type": "promise", "settings": { "eyebrow": "iii · Promise", "heading": "The pound leaves first.", "body": "£1 and 10% of profit from every pouch goes to the cause she names — before the profit is calculated. Receipts published quarterly, signed." } }
      ]
    }
  ]
}
{% endschema %}
