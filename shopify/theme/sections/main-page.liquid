{%- comment -%}
  Generic page content. Optional contact form (enabled per-template in
  page.contact.json). Policy pages share this section too.
{%- endcomment -%}
<section class="page-hero-sub">
  <div class="wrap">
    <nav class="crumb" aria-label="{{ 'general.breadcrumbs.label' | t }}">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a><span class="sep">/</span><span class="here">{{ page.title }}</span>
    </nav>
    <h1 class="page-h1">{{ page.title }}</h1>
  </div>
</section>

<section class="sys">
  <div class="wrap">
    {%- if page.content != blank -%}
      <div class="rte">{{ page.content }}</div>
    {%- endif -%}

    {%- if section.settings.show_contact_form -%}
      {% form 'contact', class: 'contact-form' %}
        {%- if form.posted_successfully? -%}
          <p class="form-status ok" role="status">{{ 'general.contact.success' | t }}</p>
        {%- elsif form.errors -%}
          <div class="form-errors" role="alert">
            <p class="form-status err">{{ 'general.contact.error' | t }}</p>
          </div>
        {%- endif -%}
        <div>
          <label for="ContactName">{{ 'general.contact.name' | t }}</label>
          <input type="text" id="ContactName" name="contact[name]" value="{{ form.name }}" autocomplete="name">
        </div>
        <div>
          <label for="ContactEmail">{{ 'general.contact.email' | t }}</label>
          <input type="email" id="ContactEmail" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
        </div>
        <div>
          <label for="ContactBody">{{ 'general.contact.message' | t }}</label>
          <textarea id="ContactBody" name="contact[body]" required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="btn btn-primary">{{ 'general.contact.send' | t }}</button>
      {% endform %}
    {%- endif -%}
  </div>
</section>

{%- render 'breadcrumb-schema' -%}

{% schema %}
{
  "name": "Page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_contact_form",
      "label": "Show contact form",
      "default": false
    }
  ]
}
{% endschema %}
