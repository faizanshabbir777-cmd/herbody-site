{%- comment -%}
  The Quarterly — migrated from the static quarterly.html. Long reads live as
  Shopify blog articles: point the section at the "quarterly" blog and every
  article renders as a numbered issue card. Until the blog has articles, the
  issue blocks below carry the founding issues so the page ships faithful on
  first deploy.
{%- endcomment -%}
{%- assign quarterly_blog = blogs[section.settings.blog_handle] -%}
<section class="page-hero-sub">
  <div class="wrap">
    <nav class="crumb" aria-label="{{ 'general.breadcrumbs.label' | t }}">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a><span class="sep">/</span><span class="here">{{ page.title }}</span>
    </nav>
    <div class="sec-id">{{ section.settings.eyebrow }}</div>
    <h1 class="page-h1">{{ section.settings.headline }}</h1>
    {%- if section.settings.lede != blank -%}<p class="sec-lede">{{ section.settings.lede }}</p>{%- endif -%}
  </div>
</section>

<section class="sys">
  <div class="wrap">
    <div class="stat-row quarterly-stats">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="stat" {{ block.shopify_attributes }}>
            <div class="stat-n tabular">{{ block.settings.value }}</div>
            <div class="stat-l">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<section class="sys">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-id">{{ section.settings.issues_eyebrow }}</div>
      <div>
        <h2 class="sec-title">{{ section.settings.issues_heading }}</h2>
        {%- if section.settings.issues_lede != blank -%}<p class="sec-lede">{{ section.settings.issues_lede }}</p>{%- endif -%}
      </div>
    </div>

    {%- if quarterly_blog and quarterly_blog.articles_count > 0 -%}
      <div class="benefit-grid">
        {%- for article in quarterly_blog.articles limit: 12 -%}
          <article class="benefit-card">
            <div class="sec-id">{{ article.published_at | date: "%b %Y" }}{% if article.tags.size > 0 %} · {{ article.tags | join: " · " }}{% endif %}</div>
            <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
            {%- if article.excerpt != blank -%}<p>{{ article.excerpt | strip_html | truncate: 180 }}</p>{%- endif -%}
            <p><a href="{{ article.url }}">Read the issue &rarr;</a></p>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="benefit-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'issue' -%}
            <article class="benefit-card" {{ block.shopify_attributes }}>
              <div class="sec-id">{{ block.settings.eyebrow }}</div>
              <h3>{{ block.settings.heading }}</h3>
              <p>{{ block.settings.body }}</p>
              <p class="quarterly-byline">{{ block.settings.byline }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "The Quarterly",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No. 03 · The Quarterly · Vol. 26" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Long reads, numbered." },
    { "type": "text", "id": "lede", "label": "Lede", "default": "Four issues a year. The formula, the partners, the audit, the women whose lives the pound is reaching. Signed by us. Sent by post and email. Never sold, never spammed." },
    { "type": "text", "id": "blog_handle", "label": "Blog handle (articles become issues)", "default": "quarterly" },
    { "type": "text", "id": "issues_eyebrow", "label": "Issues eyebrow", "default": "01 · The Issues" },
    { "type": "text", "id": "issues_heading", "label": "Issues heading", "default": "Every drop, every cause, every audit." },
    { "type": "text", "id": "issues_lede", "label": "Issues lede", "default": "No editorial calendar. We publish when there's something worth reading." }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "26" },
        { "type": "text", "id": "label", "label": "Label", "default": "Volume" }
      ]
    },
    {
      "type": "issue",
      "name": "Issue",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Vol. 26 · No. 03 · Field report · 14 min read" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "The receipt from Sindh." },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Where the first quarter's pounds went. Line by line. Signed. 78 households, four district hospitals, one refurbished maternity ward in Larkana." },
        { "type": "text", "id": "byline", "label": "Byline", "default": "By Aaliyah K. & Maryam H. · Field photography by Aamna R. · Published Mar 2026" }
      ]
    }
  ],
  "presets": [
    {
      "name": "The Quarterly",
      "blocks": [
        { "type": "stat", "settings": { "value": "26", "label": "Volume" } },
        { "type": "stat", "settings": { "value": "03", "label": "Issues this year" } },
        { "type": "stat", "settings": { "value": "14k", "label": "Readers" } },
        { "type": "stat", "settings": { "value": "4", "label": "Issues a year" } },
        { "type": "issue", "settings": { "eyebrow": "Vol. 26 · No. 03 · The Pact · audit · 14 min read", "heading": "The receipt from Sindh.", "body": "Where the first quarter's pounds went. Line by line. Signed. The mothers Pakistan flood relief reached: 78 households, four district hospitals, one refurbished maternity ward in Larkana.", "byline": "By Aaliyah K. & Maryam H. · Field photography by Aamna R. · Published Mar 2026" } },
        { "type": "issue", "settings": { "eyebrow": "Vol. 26 · No. 02 · The formula · Halal & clinical · 9 min read", "heading": "Why five grams of creatine.", "body": "The studies. The dose floor. The reason every pouch carries the studied amount, not the marketing amount — and why the trial data doesn't support pulling the dose under 5g.", "byline": "By Dr Maryam H." } }
      ]
    }
  ]
}
{% endschema %}
