<section class="page-hero-sub">
  <div class="wrap">
    <nav class="crumb" aria-label="{{ 'general.breadcrumbs.label' | t }}">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a><span class="sep">/</span><span class="here">{{ collection.title }}</span>
    </nav>
    <h1 class="page-h1">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="sec-lede">{{ collection.description | strip_html }}</p>
    {%- endif -%}
  </div>
</section>

<section class="sys">
  <div class="wrap">
    {%- paginate collection.products by 12 -%}
      {%- if collection.products.size == 0 -%}
        <div class="cart-empty">
          <span class="scrawl">{{ 'sections.collection.empty_scrawl' | t }}</span>
          <p>{{ 'sections.collection.empty' | t }}</p>
        </div>
      {%- else -%}
        <div class="coll-grid">
          {%- for product in collection.products -%}
            <a class="pcard" href="{{ product.url }}">
              <div class="pc-media">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 640 }}"
                    srcset="{{ product.featured_image | image_url: width: 320 }} 320w, {{ product.featured_image | image_url: width: 640 }} 640w"
                    sizes="(max-width: 560px) 94vw, (max-width: 900px) 46vw, 400px"
                    width="400" height="400"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy">
                {%- else -%}
                  <span class="pip" aria-hidden="true"></span>
                {%- endif -%}
              </div>
              <h3>{{ product.title }}</h3>
              <div class="pc-price">
                {%- render 'price', product: product, use_variant: true, show_from: true -%}
                {%- unless product.available %} &middot; {{ 'products.product.sold_out' | t }}{% endunless -%}
              </div>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="crumb" style="margin-top:34px;text-align:center" aria-label="{{ 'sections.collection.pagination' | t }}">
            {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr; {{ 'sections.collection.prev' | t }}</a>{%- endif -%}
            <span class="sep">{{ paginate.current_page }} / {{ paginate.pages }}</span>
            {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{{ 'sections.collection.next' | t }} &rarr;</a>{%- endif -%}
          </nav>
        {%- endif -%}
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{%- render 'breadcrumb-schema' -%}

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
