# ===== HerBody automation — example env. NEVER commit a real .env =====
# Anthropic (required for all agents)
ANTHROPIC_API_KEY=

# Shopify
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_CLI_THEME_TOKEN=
SHOPIFY_API_VERSION=2025-07

# TikTok (OmniFlash live posting + ads)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_PIXEL_ID=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Meta / Instagram / Facebook
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
META_BUSINESS_ID=

# Google
GA4_MEASUREMENT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Klaviyo
KLAVIYO_PUBLIC_KEY=
KLAVIYO_PRIVATE_KEY=

# Automation safety
ADS_AUTOMATION_MODE=draft_only
MAX_DAILY_BUDGET_GBP=25
MAX_CAMPAIGNS_PER_CHANNEL=3
MAX_ADSETS_PER_CAMPAIGN=3
MAX_ADS_PER_ADSET=5
REQUIRE_HUMAN_APPROVAL=true
